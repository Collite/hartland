package hartland

model binding

// er2db — one def er2db_entity per D-5 entity, one def er2db_attribute per er attribute
// (fixtures 12/13). Completeness rule (Stage 2.2 T2): every er attribute has a matching
// er2db_attribute — enforced by the T6 suite, not just by convention.

// ===== store_sales =====
def er2db_entity store_sales_map { entity: er.entity.store_sales, target: { table: db.dbo.store_sales } }
def er2db_attribute store_sales_item_map           { attribute: er.entity.store_sales.item,           target: { column: db.dbo.store_sales.ss_item_sk } }
def er2db_attribute store_sales_ticket_number_map   { attribute: er.entity.store_sales.ticket_number,   target: { column: db.dbo.store_sales.ss_ticket_number } }
def er2db_attribute store_sales_sold_date_map        { attribute: er.entity.store_sales.sold_date,       target: { column: db.dbo.store_sales.ss_sold_date_sk } }
def er2db_attribute store_sales_customer_map         { attribute: er.entity.store_sales.customer,        target: { column: db.dbo.store_sales.ss_customer_sk } }
def er2db_attribute store_sales_addr_map             { attribute: er.entity.store_sales.addr,             target: { column: db.dbo.store_sales.ss_addr_sk } }
def er2db_attribute store_sales_store_map            { attribute: er.entity.store_sales.store,            target: { column: db.dbo.store_sales.ss_store_sk } }
def er2db_attribute store_sales_promo_map            { attribute: er.entity.store_sales.promo,            target: { column: db.dbo.store_sales.ss_promo_sk } }
def er2db_attribute store_sales_quantity_map         { attribute: er.entity.store_sales.quantity,         target: { column: db.dbo.store_sales.ss_quantity } }
def er2db_attribute store_sales_ext_sales_price_map  { attribute: er.entity.store_sales.ext_sales_price,  target: { column: db.dbo.store_sales.ss_ext_sales_price } }

