package hartland

model db schema dbo

// Cross-table foreign keys — every fact -> dim edge the er2db relation bindings
// (Stage 2.2) reference via `binding: { fk: db.dbo.fk_… } }` (fixture 26-relation-fk-mapping),
// plus the two demographics/address chains off `customer`. Every `from`/`to` column
// already exists in facts.ttrm/dims.ttrm — a dangling ref is caught by resolution (T6).

// -- store_sales --
def fk fk_ss_item     { from: [db.dbo.store_sales.ss_item_sk],     to: [db.dbo.item.i_item_sk] }
def fk fk_ss_customer { from: [db.dbo.store_sales.ss_customer_sk], to: [db.dbo.customer.c_customer_sk] }
def fk fk_ss_addr     { from: [db.dbo.store_sales.ss_addr_sk],     to: [db.dbo.customer_address.ca_address_sk] }
def fk fk_ss_store    { from: [db.dbo.store_sales.ss_store_sk],    to: [db.dbo.store.s_store_sk] }
def fk fk_ss_promo    { from: [db.dbo.store_sales.ss_promo_sk],    to: [db.dbo.promotion.p_promo_sk] }
def fk fk_ss_date     { from: [db.dbo.store_sales.ss_sold_date_sk],to: [db.dbo.date_dim.d_date_sk] }

// -- web_sales --
def fk fk_ws_item     { from: [db.dbo.web_sales.ws_item_sk],          to: [db.dbo.item.i_item_sk] }
def fk fk_ws_customer { from: [db.dbo.web_sales.ws_bill_customer_sk], to: [db.dbo.customer.c_customer_sk] }
def fk fk_ws_addr     { from: [db.dbo.web_sales.ws_bill_addr_sk],     to: [db.dbo.customer_address.ca_address_sk] }
def fk fk_ws_promo    { from: [db.dbo.web_sales.ws_promo_sk],         to: [db.dbo.promotion.p_promo_sk] }
def fk fk_ws_date     { from: [db.dbo.web_sales.ws_sold_date_sk],     to: [db.dbo.date_dim.d_date_sk] }

// -- catalog_sales (Marketplace) --
def fk fk_cs_item       { from: [db.dbo.catalog_sales.cs_item_sk],          to: [db.dbo.item.i_item_sk] }
def fk fk_cs_customer   { from: [db.dbo.catalog_sales.cs_bill_customer_sk], to: [db.dbo.customer.c_customer_sk] }
def fk fk_cs_addr       { from: [db.dbo.catalog_sales.cs_bill_addr_sk],     to: [db.dbo.customer_address.ca_address_sk] }
def fk fk_cs_callcenter { from: [db.dbo.catalog_sales.cs_call_center_sk],   to: [db.dbo.call_center.cc_call_center_sk] }
def fk fk_cs_warehouse  { from: [db.dbo.catalog_sales.cs_warehouse_sk],     to: [db.dbo.warehouse.w_warehouse_sk] }
def fk fk_cs_promo      { from: [db.dbo.catalog_sales.cs_promo_sk],         to: [db.dbo.promotion.p_promo_sk] }
def fk fk_cs_date       { from: [db.dbo.catalog_sales.cs_sold_date_sk],     to: [db.dbo.date_dim.d_date_sk] }

// -- store_returns --
def fk fk_sr_item     { from: [db.dbo.store_returns.sr_item_sk],          to: [db.dbo.item.i_item_sk] }
def fk fk_sr_customer { from: [db.dbo.store_returns.sr_customer_sk],      to: [db.dbo.customer.c_customer_sk] }
def fk fk_sr_store    { from: [db.dbo.store_returns.sr_store_sk],         to: [db.dbo.store.s_store_sk] }
def fk fk_sr_reason   { from: [db.dbo.store_returns.sr_reason_sk],        to: [db.dbo.reason.r_reason_sk] }
def fk fk_sr_date     { from: [db.dbo.store_returns.sr_returned_date_sk], to: [db.dbo.date_dim.d_date_sk] }

// -- web_returns --
def fk fk_wr_item     { from: [db.dbo.web_returns.wr_item_sk],               to: [db.dbo.item.i_item_sk] }
def fk fk_wr_customer { from: [db.dbo.web_returns.wr_returning_customer_sk], to: [db.dbo.customer.c_customer_sk] }
def fk fk_wr_reason   { from: [db.dbo.web_returns.wr_reason_sk],             to: [db.dbo.reason.r_reason_sk] }
def fk fk_wr_date     { from: [db.dbo.web_returns.wr_returned_date_sk],      to: [db.dbo.date_dim.d_date_sk] }

// -- catalog_returns --
def fk fk_cr_item      { from: [db.dbo.catalog_returns.cr_item_sk],               to: [db.dbo.item.i_item_sk] }
def fk fk_cr_customer  { from: [db.dbo.catalog_returns.cr_returning_customer_sk], to: [db.dbo.customer.c_customer_sk] }
def fk fk_cr_reason    { from: [db.dbo.catalog_returns.cr_reason_sk],             to: [db.dbo.reason.r_reason_sk] }
def fk fk_cr_warehouse { from: [db.dbo.catalog_returns.cr_warehouse_sk],          to: [db.dbo.warehouse.w_warehouse_sk] }
def fk fk_cr_date      { from: [db.dbo.catalog_returns.cr_returned_date_sk],      to: [db.dbo.date_dim.d_date_sk] }

// -- inventory --
def fk fk_inv_item      { from: [db.dbo.inventory.inv_item_sk],      to: [db.dbo.item.i_item_sk] }
def fk fk_inv_warehouse { from: [db.dbo.inventory.inv_warehouse_sk], to: [db.dbo.warehouse.w_warehouse_sk] }
def fk fk_inv_date      { from: [db.dbo.inventory.inv_date_sk],      to: [db.dbo.date_dim.d_date_sk] }

// -- customer's own dimension chains --
def fk fk_c_addr  { from: [db.dbo.customer.c_current_addr_sk],  to: [db.dbo.customer_address.ca_address_sk] }
def fk fk_c_cdemo { from: [db.dbo.customer.c_current_cdemo_sk], to: [db.dbo.customer_demographics.cd_demo_sk] }
def fk fk_c_hdemo { from: [db.dbo.customer.c_current_hdemo_sk], to: [db.dbo.household_demographics.hd_demo_sk] }

// -- household_demographics -> income_band --
def fk fk_hd_income { from: [db.dbo.household_demographics.hd_income_band_sk], to: [db.dbo.income_band.ib_income_band_sk] }
