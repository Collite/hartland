model db schema dbo

// Physical fact tables — the demo subset (D-5 roster). Column selection: keys used by a
// q.hartland.* join (D-2) or an fk in fks.ttrm, plus the revenue/quantity/return measures
// (D-6a). Money columns are declared decimal(10,2) — the superset precision: hartland_us
// keeps the stock TPC-DS numeric(7,2), hartland_cz was widened to numeric(10,2) for the FX
// scale (Phase 1 Stage 1.3 T4); the wider declaration reads correctly against both.
//
// Deliberately NOT modeled anywhere below (D-6a — F-8 makes these nonsense-generators;
// margin questions gap gracefully, not silently wrong): *_net_profit, *_net_paid,
// *_net_paid_inc_tax, *_net_paid_inc_ship, *_net_paid_inc_ship_tax, *_wholesale_cost,
// *_list_price, *_ext_wholesale_cost, *_ext_list_price, *_ext_discount_amt, *_ext_tax,
// *_ext_ship_cost, *_coupon_amt, *_fee, *_return_ship_cost, *_refunded_cash,
// *_reversed_charge, *_store_credit / *_account_credit, *_net_loss, *_return_tax,
// *_return_amt_inc_tax. The physical columns are untouched; the model simply never
// surfaces them, so no er/md/binding path can reach them (T4/T6-4).

def table store_sales {
    description: "Stores-channel sales lines (D-5: Store Sales — beats 1-2)."
    primaryKey: [ss_item_sk, ss_ticket_number]
    columns: [
        def column ss_sold_date_sk  { type: int },
        def column ss_item_sk       { type: int, isKey: true },
        def column ss_customer_sk   { type: int },
        def column ss_addr_sk       { type: int },
        def column ss_store_sk      { type: int },
        def column ss_promo_sk      { type: int },
        def column ss_ticket_number { type: int, isKey: true },
        def column ss_quantity      { type: int },
        def column ss_ext_sales_price { type: { type: decimal, length: 10, precision: 2 } }
    ]
}

def table web_sales {
    description: "Web-channel sales lines (D-5: Web Orders — cannibalization branch)."
    primaryKey: [ws_item_sk, ws_order_number]
    columns: [
        def column ws_sold_date_sk     { type: int },
        def column ws_item_sk          { type: int, isKey: true },
        def column ws_bill_customer_sk { type: int },
        def column ws_bill_addr_sk     { type: int },
        def column ws_promo_sk         { type: int },
        def column ws_order_number     { type: int, isKey: true },
        def column ws_quantity         { type: int },
        def column ws_ext_sales_price  { type: { type: decimal, length: 10, precision: 2 } }
    ]
}

def table catalog_sales {
    description: "Marketplace-channel (3P) sales lines (D-5: Marketplace Orders — the channel of the incident, beats 1-5)."
    primaryKey: [cs_item_sk, cs_order_number]
    columns: [
        def column cs_sold_date_sk     { type: int },
        def column cs_item_sk          { type: int, isKey: true },
        def column cs_bill_customer_sk { type: int },
        def column cs_bill_addr_sk     { type: int },
        def column cs_call_center_sk   { type: int },
        def column cs_warehouse_sk     { type: int },
        def column cs_promo_sk         { type: int },
        def column cs_order_number     { type: int, isKey: true },
        def column cs_quantity         { type: int },
        def column cs_ext_sales_price  { type: { type: decimal, length: 10, precision: 2 } }
    ]
}

def table store_returns {
    description: "Stores-channel returns (D-5: Store Returns — S3 evidence)."
    primaryKey: [sr_item_sk, sr_ticket_number]
    columns: [
        def column sr_returned_date_sk { type: int },
        def column sr_item_sk          { type: int, isKey: true },
        def column sr_customer_sk      { type: int },
        def column sr_store_sk         { type: int },
        def column sr_reason_sk        { type: int },
        def column sr_ticket_number    { type: int, isKey: true },
        def column sr_return_quantity  { type: int },
        def column sr_return_amt       { type: { type: decimal, length: 10, precision: 2 } }
    ]
}

def table web_returns {
    description: "Web-channel returns (D-5: Web Returns — S3 evidence)."
    primaryKey: [wr_item_sk, wr_order_number]
    columns: [
        def column wr_returned_date_sk      { type: int },
        def column wr_item_sk               { type: int, isKey: true },
        def column wr_returning_customer_sk { type: int },
        def column wr_reason_sk             { type: int },
        def column wr_order_number          { type: int, isKey: true },
        def column wr_return_quantity       { type: int },
        def column wr_return_amt            { type: { type: decimal, length: 10, precision: 2 } }
    ]
}

def table catalog_returns {
    description: "Marketplace-channel returns (D-5: Catalog Returns — S3 evidence, the smoking gun's paired signal)."
    primaryKey: [cr_item_sk, cr_order_number]
    columns: [
        def column cr_returned_date_sk      { type: int },
        def column cr_item_sk               { type: int, isKey: true },
        def column cr_returning_customer_sk { type: int },
        def column cr_reason_sk             { type: int },
        def column cr_warehouse_sk          { type: int },
        def column cr_order_number          { type: int, isKey: true },
        def column cr_return_quantity       { type: int },
        // Note: this fact's amount column is `cr_return_amount`, not `..._amt` like its
        // sr/wr siblings (a genuine TPC-DS naming inconsistency, verified against the
        // physical schema — model/db/.schema-ref/catalog_returns.txt).
        def column cr_return_amount         { type: { type: decimal, length: 10, precision: 2 } }
    ]
}

def table inventory {
    description: "Weekly warehouse-level on-hand snapshots (D-5: Inventory Snapshots — the smoking gun, S1)."
    primaryKey: [inv_date_sk, inv_item_sk, inv_warehouse_sk]
    columns: [
        def column inv_date_sk          { type: int, isKey: true },
        def column inv_item_sk          { type: int, isKey: true },
        def column inv_warehouse_sk     { type: int, isKey: true },
        def column inv_quantity_on_hand { type: int }
    ]
}
